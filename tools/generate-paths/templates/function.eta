<% /* @formatter:off */ %>
<% const body = it.bodyType && it.isNotEmpty ? `body: ${it.bodyType}, ` : null %>
<% const responsesType = it.responseTypeMap?.map(r => `${r.status}: ${r.type}`).join('; ') ?? "undefined" %>

export const <%= it.id %> = async (<%_= body _%> <%_= it.params?.join(', ') _%><%= it.params?.length > 0 ? ', ' : null %>headers?: HeadersInit, options?: RequestInit) => await typedFetch<{ <%= responsesType %> }, <%= it.bodyType ?? 'undefined' %>>(<%= it.q %><%= it.url %><%= it.query %><%= it.q %>,
    <%= it.method.toUpperCase() %>,
    <%= it.bodyType && it.isNotEmpty ? 'body' : 'undefined' %>,
    headers,
    options,
);